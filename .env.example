# =============================================================================
# GabesVideos environment variables
# Copy this file to .env and fill in real values. Never commit .env.
# In production, set these in the Vercel project settings instead.
# =============================================================================

# -----------------------------------------------------------------------------
# Server side only. NO VITE_ PREFIX. Never imported anywhere under src/.
# Used exclusively inside the /api serverless functions so it stays secret.
# In Google Cloud, restrict this key by API (YouTube Data API v3 only).
# Do NOT restrict by HTTP referrer or IP: Vercel serverless IPs are dynamic and
# referrer restriction does not apply to server side calls. (See README.)
# -----------------------------------------------------------------------------
YOUTUBE_API_KEY=

# -----------------------------------------------------------------------------
# Client side (safe to expose, protected by Supabase row level security).
# If either is missing the app still runs: it disables sync and shows a banner.
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------------
# Client flags
# -----------------------------------------------------------------------------

# When true, the app reads src/fixtures/feed.json instead of calling /api.
# Works with no API key, no Supabase, and no network. Great for UI work and demos.
VITE_MOCK_MODE=false

# Which YouTube host the embedded player loads from.
#   https://www.youtube.com           -> Premium friendly, keeps your signed in session
#   https://www.youtube-nocookie.com  -> no session, can be friendlier to some blockers
VITE_EMBED_HOST=https://www.youtube.com
